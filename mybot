#!/usr/bin/env python3
"""mp-pdf-bot — archive 微信公众号 articles to PDF via wewe-rss + headless Chrome."""

import argparse
import os
import platform
import re
import shlex
import shutil
import sqlite3
import subprocess
import sys
import time
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent
LAUNCHD_LABEL = "com.mp-pdf-bot.wewe-rss"
PLIST_PATH = Path.home() / "Library/LaunchAgents" / f"{LAUNCHD_LABEL}.plist"
CRON_TAG = "# mp-pdf-bot"

CHROME_CANDIDATES = [
    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "/Applications/Chromium.app/Contents/MacOS/Chromium",
    "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge",
]

_INVALID_CHARS = re.compile(r'[/\\:*?"<>|\x00-\x1f]')


def sanitize_filename(name: str, max_len: int = 80) -> str:
    """Replace filesystem-invalid characters with `_`, trim to max_len."""
    cleaned = _INVALID_CHARS.sub("_", name).strip()
    return cleaned[:max_len]


def find_chrome() -> str:
    """Return the first existing Chrome-family binary path or exit with a clear message."""
    for path in CHROME_CANDIDATES:
        if Path(path).is_file():
            return path
    sys.exit(
        "找不到 Chrome / Chromium / Edge。请装 Google Chrome:\n"
        "  brew install --cask google-chrome"
    )


def load_config(path: Path) -> dict:
    """Parse a simple KEY=value env file. Supports double-quoted values, '#' comments."""
    out: dict = {}
    if not path.is_file():
        return out
    for raw in path.read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, _, value = line.partition("=")
        # shlex.split handles quoted strings cleanly (`"a b"` → `a b`)
        parts = shlex.split(value, posix=True)
        out[key.strip()] = parts[0] if parts else ""
    return out


def _run(cmd, *, cwd=None, env=None, check=True, capture=False):
    """Run a shell command list, stream or capture output."""
    print(f"$ {' '.join(map(str, cmd))}")
    if capture:
        return subprocess.run(cmd, cwd=cwd, env=env, check=check, text=True, capture_output=True)
    return subprocess.run(cmd, cwd=cwd, env=env, check=check)


def _which(prog: str):
    """Return path to `prog` or None — typed loosely for Python 3.9 compat."""
    return shutil.which(prog)


def _preflight() -> None:
    if platform.system() != "Darwin":
        sys.exit("仅支持 macOS")
    if not _which("brew"):
        sys.exit("没找到 Homebrew。装一下：https://brew.sh")
    if not _which("node"):
        sys.exit("没找到 Node.js。先装：brew install node")
    out = _run(["node", "--version"], capture=True).stdout.strip()
    major = int(out.lstrip("v").split(".")[0])
    if major < 20:
        sys.exit(f"Node 版本太旧 ({out})，需要 20+。升级：brew upgrade node")
    if not _which("git"):
        sys.exit("没找到 git")
    if not _which("pnpm"):
        print("pnpm 未安装，启用 corepack…")
        corepack_env = {**os.environ, "COREPACK_NPM_REGISTRY": "https://registry.npmmirror.com"}
        _run(["corepack", "enable"])
        _run(["corepack", "prepare", "pnpm@latest", "--activate"], env=corepack_env)
    find_chrome()  # exits if missing


def _ensure_config_env() -> dict:
    src = REPO_ROOT / "config.example.env"
    dst = REPO_ROOT / "config.env"
    if not dst.exists():
        shutil.copy(src, dst)
        print(f"已生成 config.env（默认值）：{dst}")
    return load_config(dst)


def _install_wewe_rss(cfg: dict) -> None:
    target = REPO_ROOT / "wewe-rss"
    ref = cfg.get("WEWE_RSS_REPO_REF", "v2.6.1")
    if not target.exists():
        _run(["git", "clone", "https://github.com/cooderl/wewe-rss.git", str(target)])
    _run(["git", "fetch", "--tags"], cwd=target)
    _run(["git", "checkout", ref], cwd=target)

    # Switch Prisma schema from MySQL → SQLite
    mysql_dir = target / "apps/server/prisma"
    sqlite_dir = target / "apps/server/prisma-sqlite"
    if sqlite_dir.exists():
        if mysql_dir.exists():
            shutil.rmtree(mysql_dir)
        shutil.move(str(sqlite_dir), str(mysql_dir))

    data_dir = REPO_ROOT / cfg.get("DATA_DIR", "./data").lstrip("./")
    data_dir.mkdir(parents=True, exist_ok=True)

    env_path = target / ".env"
    port = cfg.get("WEWE_RSS_PORT", "4000")
    auth = cfg.get("AUTH_CODE", "mp-pdf-bot")
    db_url = f"file:{data_dir.resolve()}/wewe-rss.db"
    env_content = (
        f"DATABASE_URL={db_url}\n"
        f"DATABASE_TYPE=sqlite\n"
        f"AUTH_CODE={auth}\n"
        f"FEED_MODE=fulltext\n"
        f"SERVER_ORIGIN_URL=http://localhost:{port}\n"
    )
    env_path.write_text(env_content)
    # The NestJS server runs with CWD=apps/server and loads .env from there
    (target / "apps/server/.env").write_text(env_content)

    # pnpm 11+ requires explicit approval for build scripts.
    # It writes allowBuilds entries to pnpm-workspace.yaml; set them all to true.
    _BUILD_PKGS = [
        "@nestjs/core",
        "@prisma/client",
        "@prisma/engines",
        "esbuild",
        "prisma",
        "sharp",
    ]
    ws_path = target / "pnpm-workspace.yaml"
    if ws_path.exists():
        ws_text = ws_path.read_text()
        # Replace placeholder value with true for each build pkg
        ws_text = ws_text.replace("set this to true or false", "true")
        # Ensure allowBuilds section exists for each required package
        for pkg in _BUILD_PKGS:
            if pkg not in ws_text:
                # Append to allowBuilds section if missing
                if "allowBuilds:" in ws_text:
                    ws_text = ws_text.rstrip() + f"\n  '{pkg}': true\n"
                else:
                    ws_text = ws_text.rstrip() + "\nallowBuilds:\n"
                    for p in _BUILD_PKGS:
                        ws_text += f"  '{p}': true\n"
                break
        ws_path.write_text(ws_text)

    # Use npmmirror.com as registry for friends without VPN.
    # Also redirect Prisma binary downloads (which otherwise hit binaries.prisma.sh).
    npm_env = {
        **os.environ,
        "npm_config_registry": "https://registry.npmmirror.com",
        "PRISMA_ENGINES_MIRROR": "https://registry.npmmirror.com/-/binary/prisma",
        "PRISMA_BINARIES_MIRROR": "https://registry.npmmirror.com/-/binary/prisma",
    }
    print("(使用 npmmirror.com 镜像加速)")
    _run(["pnpm", "install"], cwd=target, env=npm_env)
    # Use pnpm --filter server exec to run the project-local prisma (v5.x),
    # not a globally-downloaded one; schema path is relative to apps/server.
    # Pass DATABASE_URL explicitly so prisma doesn't look for .env in cwd.
    prisma_env = {**npm_env, "DATABASE_URL": db_url}
    prisma_schema = "prisma/schema.prisma"
    _run(["pnpm", "--filter", "server", "exec", "prisma", "generate", f"--schema={prisma_schema}"],
         cwd=target, env=prisma_env)
    _run(["pnpm", "--filter", "server", "exec", "prisma", "migrate", "deploy", f"--schema={prisma_schema}"],
         cwd=target, env=prisma_env)
    _run(["pnpm", "run", "-r", "build"], cwd=target, env=npm_env)


def _install_launchd(cfg: dict) -> None:
    logs_dir = REPO_ROOT / "logs"
    logs_dir.mkdir(exist_ok=True)
    template = (REPO_ROOT / "lib/plist_template.xml").read_text()

    pnpm_path = _which("pnpm") or sys.exit("pnpm 找不到（应该不该到这一步）")
    node_dir = str(Path(_which("node")).parent)
    path_env = f"{node_dir}:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"

    plist = template.format(
        label=LAUNCHD_LABEL,
        pnpm_path=pnpm_path,
        wewe_rss_dir=str(REPO_ROOT / "wewe-rss"),
        path_env=path_env,
        stdout_log=str(logs_dir / "wewe-rss.log"),
        stderr_log=str(logs_dir / "wewe-rss.err.log"),
    )
    PLIST_PATH.parent.mkdir(parents=True, exist_ok=True)
    PLIST_PATH.write_text(plist)
    # macOS 26+ stamps com.apple.provenance on Python-created files; launchd
    # then refuses to bootstrap with cryptic "Input/output error 5". Strip it.
    subprocess.run(["xattr", "-c", str(PLIST_PATH)], capture_output=True)

    # bootout if already loaded; ignore failure (not loaded → ok). Sleep so
    # launchd finishes async unload before bootstrap (avoids "I/O error 5").
    subprocess.run(
        ["launchctl", "bootout", f"gui/{os.getuid()}/{LAUNCHD_LABEL}"],
        capture_output=True,
    )
    import time as _time
    _time.sleep(2)
    _run(["launchctl", "bootstrap", f"gui/{os.getuid()}", str(PLIST_PATH)])


def _install_cron(cfg: dict) -> None:
    cron_time = cfg.get("CRON_TIME", "0 18 * * *")
    sync_log = REPO_ROOT / "logs/sync.log"
    new_line = (
        f'{cron_time} cd {REPO_ROOT} && ./mybot sync >> {sync_log} 2>&1 {CRON_TAG}'
    )

    existing = subprocess.run(
        ["crontab", "-l"], capture_output=True, text=True
    ).stdout
    kept = [ln for ln in existing.splitlines() if CRON_TAG not in ln]
    kept.append(new_line)
    new_crontab = "\n".join(kept) + "\n"
    subprocess.run(["crontab", "-"], input=new_crontab, text=True, check=True)
    print(f"cron 已装：{cron_time}")


LAUNCHD_GUI_LABEL = "com.mp-pdf-bot.gui"
GUI_PLIST_PATH = Path.home() / "Library/LaunchAgents" / f"{LAUNCHD_GUI_LABEL}.plist"


def _install_gui(cfg: dict) -> None:
    venv = REPO_ROOT / ".venv"
    if not venv.exists():
        _run([sys.executable, "-m", "venv", str(venv)])

    pip = venv / "bin" / "pip"
    pip_env = {
        **os.environ,
        "PIP_INDEX_URL": "https://pypi.tuna.tsinghua.edu.cn/simple",
    }
    # System Python's venv ships pip 21 — too old to find arm64 pyobjc wheels
    # (rumps' transitive dep). Upgrade pip first so prebuilt wheels are used.
    _run([str(pip), "install", "--upgrade", "pip"], env=pip_env)
    _run([str(pip), "install", "-r", str(REPO_ROOT / "requirements-gui.txt")],
         env=pip_env)

    logs_dir = REPO_ROOT / "logs"
    logs_dir.mkdir(exist_ok=True)
    template = (REPO_ROOT / "lib/gui_plist_template.xml").read_text()
    venv_python = str(venv / "bin" / "python3")
    server_script = str(REPO_ROOT / "gui" / "server.py")
    path_env = "/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"

    plist = template.format(
        label=LAUNCHD_GUI_LABEL,
        python_path=venv_python,
        server_script=server_script,
        repo_root=str(REPO_ROOT),
        path_env=path_env,
        stdout_log=str(logs_dir / "gui.log"),
        stderr_log=str(logs_dir / "gui.err.log"),
    )
    GUI_PLIST_PATH.parent.mkdir(parents=True, exist_ok=True)
    GUI_PLIST_PATH.write_text(plist)
    subprocess.run(["xattr", "-c", str(GUI_PLIST_PATH)], capture_output=True)

    subprocess.run(
        ["launchctl", "bootout", f"gui/{os.getuid()}/{LAUNCHD_GUI_LABEL}"],
        capture_output=True,
    )
    import time as _time
    _time.sleep(2)
    _run(["launchctl", "bootstrap", f"gui/{os.getuid()}", str(GUI_PLIST_PATH)])
    print(f"GUI 已装：菜单栏图标 + http://localhost:{cfg.get('GUI_PORT', '4001')}/")


def cmd_setup(args):
    print("== 1. 环境检查 ==")
    _preflight()
    print("== 2. 配置 ==")
    cfg = _ensure_config_env()
    print("== 3. 安装 wewe-rss ==")
    _install_wewe_rss(cfg)
    print("== 4. 注册 launchd ==")
    _install_launchd(cfg)
    print("== 5. 装 cron ==")
    _install_cron(cfg)
    print("== 6. 安装 GUI ==")
    _install_gui(cfg)
    print(
        f"\n✅ 装好了。下一步：\n"
        f"  浏览器：http://localhost:{cfg.get('GUI_PORT', '4001')}/\n"
        f"  菜单栏：找顶部的 🟢 mp-pdf-bot 图标\n"
        f"  加公众号：菜单栏 → Open Dashboard → 扫码登录微信读书 → 添加"
    )

def _fetch_articles(db_path: Path):
    con = sqlite3.connect(db_path)
    rows = con.execute("""
        SELECT a.id, a.title, a.publish_time, f.mp_name
          FROM articles a
          JOIN feeds f ON a.mp_id = f.id
         ORDER BY a.publish_time DESC
    """).fetchall()
    con.close()
    return rows


def _render_pdf(chrome: str, url: str, outfile: Path) -> bool:
    cmd = [
        chrome,
        "--headless=new",
        "--disable-gpu",
        "--no-sandbox",
        "--hide-scrollbars",
        "--virtual-time-budget=15000",
        "--run-all-compositor-stages-before-draw",
        "--no-pdf-header-footer",
        f"--print-to-pdf={outfile}",
        url,
    ]
    try:
        subprocess.run(cmd, check=True, capture_output=True, timeout=60)
        return outfile.exists() and outfile.stat().st_size > 1024
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired):
        return False


def cmd_sync(args):
    cfg = load_config(REPO_ROOT / "config.env")
    if not cfg:
        sys.exit("没找到 config.env，先跑 ./mybot setup")

    data_dir = (REPO_ROOT / cfg.get("DATA_DIR", "./data").lstrip("./")).resolve()
    db = data_dir / "wewe-rss.db"
    if not db.exists():
        sys.exit(f"DB 不存在：{db}\n等 wewe-rss 拉过文章再跑 sync")

    out_root = (REPO_ROOT / cfg.get("PDF_OUTPUT_DIR", "./pdfs").lstrip("./")).resolve()
    out_root.mkdir(parents=True, exist_ok=True)
    chrome = find_chrome()

    rows = _fetch_articles(db)
    if not rows:
        print("没有可下载的文章。先到 ./mybot open 加公众号")
        return

    print(f"共 {len(rows)} 篇")
    ok = skip = fail = 0
    for i, (aid, title, ts, mp_name) in enumerate(rows, 1):
        date = time.strftime("%Y%m%d", time.localtime(ts))
        out_dir = out_root / sanitize_filename(mp_name)
        out_dir.mkdir(parents=True, exist_ok=True)
        outfile = out_dir / f"{date}-{sanitize_filename(title)}.pdf"
        url = f"https://mp.weixin.qq.com/s/{aid}"

        if outfile.exists():
            skip += 1
            continue

        print(f"[{i:>3}/{len(rows)}]  →   {outfile.name}", flush=True)
        if _render_pdf(chrome, url, outfile):
            ok += 1
        else:
            fail += 1
            print(f"        ⚠ 失败：{url}")
        time.sleep(0.5)

    print(f"\n完成：成功 {ok} / 跳过 {skip} / 失败 {fail}")
    print(f"输出：{out_root}")

def _config_or_exit() -> dict:
    cfg = load_config(REPO_ROOT / "config.env")
    if not cfg:
        sys.exit("没找到 config.env，先跑 ./mybot setup")
    return cfg


def cmd_open(args):
    cfg = _config_or_exit()
    port = cfg.get("WEWE_RSS_PORT", "4000")
    url = f"http://localhost:{port}/dash"
    print(f"打开 {url}")
    subprocess.run(["open", url])


def cmd_logs(args):
    log = REPO_ROOT / "logs/wewe-rss.log"
    err = REPO_ROOT / "logs/wewe-rss.err.log"
    if not log.exists() and not err.exists():
        sys.exit(f"日志还没生成：{log}")
    # tail -f both, simplest UX
    subprocess.run(["tail", "-f", str(log), str(err)])


def cmd_start(args):
    if not PLIST_PATH.exists():
        sys.exit("没找到 launchd plist。先跑 ./mybot setup")
    _run(["launchctl", "bootstrap", f"gui/{os.getuid()}", str(PLIST_PATH)])


def cmd_stop(args):
    if not PLIST_PATH.exists():
        sys.exit("没找到 launchd plist")
    _run(
        ["launchctl", "bootout", f"gui/{os.getuid()}/{LAUNCHD_LABEL}"],
        check=False,
    )


def cmd_status(args):
    cfg = _config_or_exit()
    port = cfg.get("WEWE_RSS_PORT", "4000")

    print("== launchd ==")
    r = subprocess.run(
        ["launchctl", "print", f"gui/{os.getuid()}/{LAUNCHD_LABEL}"],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        for ln in r.stdout.splitlines():
            if any(k in ln for k in ("state =", "pid =", "last exit code")):
                print(" ", ln.strip())
    else:
        print("  launchd 未注册")

    print("\n== HTTP ==")
    r = subprocess.run(
        ["curl", "--noproxy", "*", "-s", "-o", "/dev/null",
         "-w", "%{http_code}", f"http://localhost:{port}"],
        capture_output=True, text=True,
    )
    print(f"  http://localhost:{port} → {r.stdout.strip() or 'no response'}")

    db = (REPO_ROOT / cfg.get("DATA_DIR", "./data").lstrip("./") / "wewe-rss.db")
    if db.exists():
        print(f"\n== DB ==\n  {db} ({db.stat().st_size // 1024} KB)")

    pdfs_dir = (REPO_ROOT / cfg.get("PDF_OUTPUT_DIR", "./pdfs").lstrip("./"))
    if pdfs_dir.exists():
        count = sum(1 for _ in pdfs_dir.rglob("*.pdf"))
        print(f"\n== PDF ==\n  {pdfs_dir} ({count} 个)")

def cmd_uninstall(args):
    print("== 移除 launchd ==")
    subprocess.run(
        ["launchctl", "bootout", f"gui/{os.getuid()}/{LAUNCHD_LABEL}"],
        capture_output=True,
    )
    if PLIST_PATH.exists():
        PLIST_PATH.unlink()
        print(f"  删除 {PLIST_PATH}")

    print("\n== 移除 cron ==")
    existing = subprocess.run(
        ["crontab", "-l"], capture_output=True, text=True
    ).stdout
    kept = [ln for ln in existing.splitlines() if CRON_TAG not in ln]
    new_crontab = "\n".join(kept) + ("\n" if kept else "")
    if new_crontab.strip():
        subprocess.run(["crontab", "-"], input=new_crontab, text=True, check=True)
    else:
        subprocess.run(["crontab", "-r"], capture_output=True)
    print("  crontab 中的 mp-pdf-bot 行已删除")

    wewe = REPO_ROOT / "wewe-rss"
    if wewe.exists():
        shutil.rmtree(wewe)
        print(f"\n  删除 {wewe}（源码 / build 产物）")

    cfg = load_config(REPO_ROOT / "config.env")
    data_dir = REPO_ROOT / cfg.get("DATA_DIR", "./data").lstrip("./")
    pdfs = REPO_ROOT / cfg.get("PDF_OUTPUT_DIR", "./pdfs").lstrip("./")
    print(
        f"\n保留：\n"
        f"  {data_dir}（SQLite 数据库）\n"
        f"  {pdfs}（已生成的 PDF）\n"
        f"  config.env\n"
        f"想完全清理：rm -rf {data_dir} {pdfs} config.env"
    )


def build_parser():
    p = argparse.ArgumentParser(prog="mybot", description=__doc__)
    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("setup", help="一次性安装")
    sub.add_parser("sync", help="拉新文章 + 转 PDF")
    sub.add_parser("open", help="浏览器打开 wewe-rss 后台")
    sub.add_parser("logs", help="查看运行日志")
    sub.add_parser("start", help="启动服务")
    sub.add_parser("stop", help="停止服务")
    sub.add_parser("status", help="显示运行状态")
    sub.add_parser("uninstall", help="卸载服务和定时任务")
    return p


HANDLERS = {
    "setup": cmd_setup,
    "sync": cmd_sync,
    "open": cmd_open,
    "logs": cmd_logs,
    "start": cmd_start,
    "stop": cmd_stop,
    "status": cmd_status,
    "uninstall": cmd_uninstall,
}


def main():
    args = build_parser().parse_args()
    HANDLERS[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
